# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ─────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Environment secrets ───────────────────────────────────
.env

# ── Logs — written to host-mounted volume, not in repo ────────────────────────
*.log
logs/
airflow/logs/

# ── Data files — tracked by DVC, not Git ──────────────────────────────────────
airflow/data/raw/
airflow/data/processed/
*.csv
*.txt
!airflow/dags/*.txt   # keep any text fixtures in dags/

# ── MLflow artifacts ──────────────────────────────────────────────────────────
mlflow/artifacts/
mlflow/mlflow.db
mlflow/*.db

# ── Model files ───────────────────────────────────────────────────────────────
*.pkl
*.pt
*.pth
*.onnx

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── DVC cache (large binary blobs, not for git) ───────────────────────────────
.dvc/cache/
.dvc/tmp/

# ── OS junk ───────────────────────────────────────────────────────────────────
.DS_Store
__MACOSX/
Thumbs.db
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Docker ────────────────────────────────────────────────────────────────────
# (docker-compose.yml IS committed — only ignore override files)
docker-compose.override.yml
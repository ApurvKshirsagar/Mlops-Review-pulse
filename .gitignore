airflow/airflow.cfg

# Data files (managed by DVC - ignore actual data, not .dvc pointer files)
airflow/data/raw/sentiment labelled sentences/
airflow/data/processed/
!airflow/data/**/*.dvc
!airflow/data/.gitignore

# MLflow generated files
mlflow/artifacts/
mlflow/*.db

# Generic artifacts outside of data folder
*.zip
    
# OS files
.DS_Store
Thumbs.db


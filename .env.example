# ─────────────────────────────────────────────────────────────
# .env.example  — copy this to .env and fill in your values
# .env is in .gitignore 
# ─────────────────────────────────────────────────────────────

# ── Paths (used by Airflow DAG + backend) ─────────────────────
RAW_DIR=/opt/airflow/data/raw
PROCESSED_DIR=/opt/airflow/data/processed
MODEL_DIR=/opt/mlflow/artifacts/models
LOG_DIR=/opt/logs

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_URI=http://mlflow:5000
MODEL_NAME=sentiment-tfidf-lr
MODEL_STAGE=Production

# ── App ───────────────────────────────────────────────────────
APP_VERSION=1.0.0
APP_NAME=Review Pulse API

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Monitoring (Grafana) ──────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Drift Detection ───────────────────────────────────────────
# KL-divergence threshold — if exceeded, model retraining is triggered
DRIFT_THRESHOLD=0.1
# Set to false to only log drift without triggering retraining
RETRAIN_ON_DRIFT=true

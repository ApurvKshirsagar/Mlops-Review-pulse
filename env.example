# ── Paths (used by Airflow DAG + backend) ─────────────────────
RAW_DIR=/opt/airflow/data/raw
PROCESSED_DIR=/opt/airflow/data/processed
MODEL_DIR=/opt/mlflow/artifacts/models
LOG_DIR=/opt/logs

# ── MLflow ────────────────────────────────────────────────────
MLFLOW_URI=http://mlflow:5000
MODEL_NAME=sentiment-tfidf-lr
MODEL_STAGE=Production

# ── App ───────────────────────────────────────────────────────
APP_VERSION=1.0.0
APP_NAME=Review Pulse API

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ── Monitoring (Grafana) ──────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Drift Detection ───────────────────────────────────────────
# KL-divergence threshold — if exceeded, model retraining is triggered
DRIFT_THRESHOLD=0.1
# Set to false to only log drift without triggering retraining
RETRAIN_ON_DRIFT=true

# ── Email Alerting (Airflow + Alertmanager) ───────────────────────────────
# ALERT_EMAIL_TO: where all alert emails go (your inbox)
# ALERT_EMAIL_FROM: Gmail address used to send
# ALERT_EMAIL_PASSWORD: Gmail App Password (NOT your login password)
#   Generate at: https://myaccount.google.com/apppasswords
ALERT_EMAIL_TO=your@email.com
ALERT_EMAIL_FROM=your.gmail@gmail.com
ALERT_EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Airflow SMTP config (mirrors the above for Airflow's built-in mailer)
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_USER=your.gmail@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
AIRFLOW__SMTP__SMTP_MAIL_FROM=your.gmail@gmail.com

# ── Pipeline Alerting ─────────────────────────────────────────────────────
# How old data files must be (hours) before a Dry Pipeline alert fires
DRY_PIPELINE_HOURS=12

# Prometheus Pushgateway (used by Airflow DAG to push pipeline metrics)
PROMETHEUS_PUSHGATEWAY=http://pushgateway:9091
